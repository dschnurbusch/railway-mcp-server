# Required: API key for authenticating MCP clients
# Generate with: openssl rand -hex 32
MCP_API_KEY=your-secret-key-here

# Optional: port (Railway sets this automatically)
PORT=3000

# Optional: CourtListener API token for citation validation
# Without this, you get 100 requests/day. With it: 5,000/hour, 60 valid citations/minute.
# Get a free token at https://www.courtlistener.com/sign-in/
COURTLISTENER_API_TOKEN=
