# Required: API key for authenticating MCP clients
# Generate with: openssl rand -hex 32
MCP_API_KEY=your-secret-key-here

# Optional: port (Railway sets this automatically)
PORT=3000

# ── Gmail ─────────────────────────────────────────────────────────────────────
# Used by: fetch_emails
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=

# ── Airtable ──────────────────────────────────────────────────────────────────
# Used by: list_airtable_bases, list_airtable_tables, list_records, get_record,
#          search_records, create_record, update_record, upsert_record,
#          delete_record, get_matter_comments, add_matter_comment
AIRTABLE_API_TOKEN=
AIRTABLE_BASE_ID=            # Default base (optional for generic tools; required for matter tools)
AIRTABLE_MATTERS_TABLE=      # Used by get_matter_comments / add_matter_comment

# ── Lawmatics ─────────────────────────────────────────────────────────────────
# Used by: find_contact_by_email, find_contact_by_phone, get_contact,
#          list_contacts, create_contact, update_contact, list_matters,
#          get_matter, create_matter, update_matter, list_time_entries,
#          create_time_entry, list_expenses, create_expense
# OAuth 2.0 — obtain a long-lived access token via the authorization code flow
# (contact api@lawmatics.com to enable Developer Settings on your account)
LAWMATICS_CLIENT_ID=       # From app.lawmatics.com/settings/developers
LAWMATICS_CLIENT_SECRET=   # From app.lawmatics.com/settings/developers
LAWMATICS_ACCESS_TOKEN=    # Auto-filled by: node scripts/lawmatics-auth.mjs

# ── Google (Sheets, Docs, Drive, Search Console) ──────────────────────────────
# Used by: get_spreadsheet_info, read_sheet_range, write_sheet_range,
#          append_sheet_rows, batch_update_sheet, create_spreadsheet,
#          get_document, create_document, append_to_document, replace_text,
#          insert_text, list_drive_files, get_file_info, create_folder,
#          share_file, move_file, list_search_console_sites,
#          query_search_analytics, inspect_url, list_sitemaps, submit_sitemap
# Scopes needed: sheets, docs, drive, webmasters, search.console.readonly
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# ── Google Ads ────────────────────────────────────────────────────────────────
# Used by: list_ad_customers, list_campaigns, query_ad_performance,
#          create_campaign, update_campaign, list_ad_groups, list_keywords,
#          create_keyword
# Apply for a developer token at: https://developers.google.com/google-ads/api/docs/get-started/dev-token
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=      # Default customer ID (digits only, no dashes)

# ── Meta / Facebook Ads ───────────────────────────────────────────────────────
# Used by: list_ad_accounts, list_fb_campaigns, get_fb_campaign,
#          create_fb_campaign, update_fb_campaign, list_ad_sets,
#          get_ad_insights, list_fb_ads
# Use a System User token from Meta Business Manager for production
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=          # e.g. act_123456789 (or just 123456789)

# ── OpenPhone ─────────────────────────────────────────────────────────────────
# Used by: fetch_text_history
OPENPHONE_API_KEY=
OPENPHONE_PHONE_NUMBER_ID=

# ── CallRail ──────────────────────────────────────────────────────────────────
# Used by: list_calls, get_call, update_call, get_call_recording,
#          list_texts, send_text, list_form_submissions, list_tags
CALLRAIL_API_KEY=
CALLRAIL_ACCOUNT_ID=

# ── Missive ───────────────────────────────────────────────────────────────────
# Used by: list_conversations, get_conversation, list_conversation_messages,
#          create_draft, create_post, list_missive_contacts,
#          create_missive_contact, update_missive_contact, list_shared_labels
# Requires Productive plan or higher
MISSIVE_API_TOKEN=

# ── CourtListener ─────────────────────────────────────────────────────────────
# Used by: search_cases, get_docket, list_docket_entries, get_opinion,
#          verify_citations, create_docket_alert, list_courts, get_parties
# Free account at courtlistener.com — token in your profile settings
COURTLISTENER_API_TOKEN=

# ── Earth Class Mail ──────────────────────────────────────────────────────────
# Used by: list_inboxes, list_mail, get_mail_piece, get_mail_content,
#          request_scan, email_scan, forward_mail, archive_mail
# Generate key: Settings → Integrations → Custom API integration
EARTH_CLASS_MAIL_API_KEY=

# ── DocuPost ──────────────────────────────────────────────────────────────────
# Used by: send_mailing
DOCUPOST_API_TOKEN=
DOCUPOST_FROM_NAME=
DOCUPOST_FROM_ADDRESS=
DOCUPOST_FROM_CITY=
DOCUPOST_FROM_STATE=
DOCUPOST_FROM_ZIP=

# ── QuickBooks Online ──────────────────────────────────────────────────────────
# Used by: qb_profit_loss, qb_balance_sheet, qb_cash_flow,
#          qb_trial_balance, qb_expenses_by_vendor
# OAuth 2.0 — obtain via Intuit Developer Portal (developer.intuit.com)
# Scopes needed: com.intuit.quickbooks.accounting
QB_CLIENT_ID=
QB_CLIENT_SECRET=
QB_REFRESH_TOKEN=
QB_REALM_ID=               # Company ID — found in your QBO URL: /app/homepage?&company=XXXXXXXX
QB_ENVIRONMENT=production  # "sandbox" or "production"
